{
    "name": "VQA_CNN_LSTM_ViInfoGraphic",
    "n_gpu": 1,

    "arch": {
        "type": "CNNLSTMBaseline",
        "args": {
            "hidden_dim": 512,
            "lstm_layers": 2,
            "embed_dim": 300,
            "max_len": 64
        }
    },
    "data_loader": {
        "type": "VQADataLoader",
        "args":{
            "data_dir": "data/viinfographic",
            "batch_size": 32,
            "shuffle": true,
            "validation_split": 0.0,
            "num_workers": 2,
            "img_size": 224
        }
    },
    "optimizer": {
        "type": "Adam",
        "args":{
            "lr": 0.001,
            "weight_decay": 0,
            "amsgrad": true
        }
    },
    "loss": "cross_entropy_loss",
    "metrics": [
    ],
    "lr_scheduler": {
        "type": "StepLR",
        "args": {
            "step_size": 50,
            "gamma": 0.1
        }
    },
    "trainer": {
        "epochs": 10,
        "save_dir": "saved/",
        "save_period": 1,
        "verbosity": 2,
        
        "monitor": "max val_vqa_accuracy",
        "early_stop": 10,

        "tensorboard": true
    }
}
